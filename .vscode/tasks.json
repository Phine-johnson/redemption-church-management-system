{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Client: Dev Server",
      "type": "npm",
      "script": "dev:client",
      "path": "",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "ready in|Local:"
        }
      }
    },
    {
      "label": "Server: Dev Server",
      "type": "npm",
      "script": "dev:server",
      "path": "",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "running on port"
        }
      }
    },
    {
      "label": "Run Full Stack",
      "dependsOn": [
        "Client: Dev Server",
        "Server: Dev Server"
      ],
      "dependsOrder": "parallel"
    }
  ]
}
